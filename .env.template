# Personal OS — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.

# ── School ──────────────────────────────────────────────────────────
CANVAS_TOKEN=your_canvas_api_token_here
CANVAS_URL=https://browardschools.instructure.com
CANVAS_CAREER_TECH_ID=1960295
CANVAS_SCIENCE_ID=1959399

SAVVAS_TOKEN=Bearer eyJ...   # refreshed automatically by savvas_refresh_token.py
